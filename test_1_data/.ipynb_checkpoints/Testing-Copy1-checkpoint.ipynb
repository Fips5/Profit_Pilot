   "source": [
    "from ib_insync import IB, Fill\n",
    "import pandas as pd\n",
    "from datetime import datetime, timedelta\n",
    "import asyncio\n",
    "import time\n",
    "class IBKRClient:\n",
    "    def __init__(self, host='127.0.0.1', port=7496, client_id=1):\n",
    "        self.ib = IB()\n",
    "        self.host = host\n",
    "        self.port = port\n",
    "        self.client_id = client_id\n",
    "\n",
    "    async def connect(self):\n",
    "        if not self.ib.isConnected():\n",
    "            await self.ib.connectAsync(self.host, self.port, clientId=self.client_id)\n",
    "\n",
    "    async def get_fills(self, days_back=1):\n",
    "            async def get_fills(self, days_back=1):\n",
    "        await self.connect()\n",
    "        fills: list[Fill] = self.ib.fills()\n",
    "        print(\"🔍 Raw fills returned by IBKR:\")\n",
    "        for f in fills:\n",
    "            print(f)\n",
    "\n",
    "        cutoff = datetime.now() - timedelta(days=days_back)\n",
    "        filtered = [\n",
    "            {\n",
    "                'Time': f.execution.time.strftime('%Y-%m-%d %H:%M:%S'),\n",
    "                'Symbol': f.contract.symbol,\n",
    "                'Action': f.execution.side,\n",
    "                'Quantity': f.execution.shares,\n",
    "                'Price': f.execution.price,\n",
    "                'Commission': f.execution.commission,\n",
    "                'Order ID': f.execution.orderId,\n",
    "                'Exchange': f.execution.exchange\n",
    "            }\n",
    "            for f in fills if f.execution.time.replace(tzinfo=None) >= cutoff\n",
    "        ]\n",
    "\n",
    "        print(f\"✅ Filtered {len(filtered)} fills after date cutoff\")\n",
    "        return pd.DataFrame(filtered)\n",
    "\n",
    "\n",
    "# Notebook-compatible async run\n",
    "async def run_ibkr_export():\n",
    "    client = IBKRClient()\n",
    "    df = await client.get_fills(days_back=30)\n",
    "    csv_path = 'ibkr_daily_trades.csv'\n",
    "    df.to_csv(csv_path, index=False)\n",
    "    print(df)\n",
    "    print(f\"✅ IBKR trades saved to {csv_path}\")\n",
    "    client.disconnect()\n",
    "\n",
    "# Run in Jupyter or other async environment\n",
    "await run_ibkr_export()\n"
   ]
  },
