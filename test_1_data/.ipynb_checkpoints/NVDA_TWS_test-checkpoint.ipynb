    "def fetch_polygon_data(ticker, timespan, first_pred=False, limit=500, intervel_time=15):\n",
    "    \"\"\"Fetch historical data from Polygon.io.\"\"\"\n",
    "    api_key = \"6FScTtPXo3hC4lyzkRb29mNJOOmLYwYF\"\n",
