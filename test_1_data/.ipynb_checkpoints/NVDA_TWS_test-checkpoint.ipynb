    "        # Use the day before the first timestamp in live_df\n",
    "        live_date = pd.to_datetime(live_df['timestamp'].iloc[0]) - pd.Timedelta(days=1)\n",
    "        # Format the date as YYYY-MM-DD for Polygon API\n",
