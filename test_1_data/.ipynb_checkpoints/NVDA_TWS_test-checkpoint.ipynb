    "}\n",
    "\n",
    "best_params_df = pd.read_csv(f'NVDA/NVDA_best_params.csv')\n",
    "best_params = best_params_df.iloc[0]\n",
    "\n",
    "if USE_STATIC_COV == False:\n",
