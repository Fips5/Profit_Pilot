    "\n",
    "            symbols_sentiment_results.append({\n",
    "                \"symbol\": symbol,\n",
    "                \"general_sentiment_score\": general_sentiment_score\n",
    "            })\n",
    "        else:\n",
    "            symbols_sentiment_results.append({\n",
    "                \"symbol\": symbol,\n",
    "                \"general_sentiment_score\": 0\n",
    "            })\n",
    "\n",
    "    df = pd.DataFrame(symbols_sentiment_results)\n",
