    "import pandas as pd\n",
    "import time\n",
    "from datetime import datetime, timedelta\n",
    "\n",
    "def get_historical_data(ticker, interval, start_date, end_date):\n",
    "    # This should replicate get_live_stock_data but fetch historical data from Twelve Data\n",
    "    # Assuming you have a function `fetch_twelve_data` similar to your live fetch\n",
    "    df = fetch_twelve_data(ticker=ticker, interval=interval, start_date=start_date, end_date=end_date)\n",
    "    df = df.reset_index(drop=True)\n",
    "    if df['timestamp'].iloc[-1] < df['timestamp'].iloc[0]:\n",
    "        df = df.iloc[::-1].reset_index(drop=True)\n",
    "    return df\n",
    "\n",
    "# Set backtest parameters\n",
    "ticker_bt = ticker\n",
    "end_date = datetime.utcnow()\n",
    "start_date = end_date - timedelta(days=7)\n",
    "\n",
    "df_1min_hist = get_historical_data(ticker_bt, interval=\"1min\", start_date=start_date, end_date=end_date)\n",
    "df_5min_hist = get_historical_data(ticker_bt, interval=\"5min\", start_date=start_date, end_date=end_date)\n",
    "df_hourly_hist = get_historical_data(ticker_bt, interval=\"1h\", start_date=start_date, end_date=end_date)\n",
    "\n",
    "# Initialize simulation variables\n",
    "pos = 0\n",
    "both_price = None\n",
    "profit_constant = 0.0062\n",
    "trade_log = []\n",
    "\n",
    "# Loop through the historical data as if live\n",
    "for i in range(len(df_1min_hist)):\n",
    "    # Simulate live slice\n",
    "    current_1min = df_1min_hist.iloc[:i+1].copy()\n",
    "    current_5min = df_5min_hist[df_5min_hist['timestamp'] <= current_1min['timestamp'].iloc[-1]].copy()\n",
    "    current_hourly = df_hourly_hist[df_hourly_hist['timestamp'] <= current_1min['timestamp'].iloc[-1]].copy()\n",
    "\n",
    "    if USE_STATIC_COV:\n",
    "        signal, long_signal, long_highest_forecast = buy_signal(\n",
    "            n_df=current_5min, model=model, min_df=current_1min,\n",
    "            static_covariates=static_covariates,\n",
    "            first_pred=True, n=5,\n",
    "            forecasting_horizon=5, long_model=long_model,\n",
    "            long_n_df=current_hourly\n",
    "        )\n",
    "    else:\n",
    "        signal, long_signal, long_highest_forecast = buy_signal(\n",
    "            n_df=current_5min, model=model, min_df=current_1min,\n",
    "            first_pred=True, n=5,\n",
    "            forecasting_horizon=5, long_model=long_model,\n",
    "            long_n_df=current_hourly\n",
    "        )\n",
    "\n",
    "    trade_info = None\n",
    "\n",
    "    # BUY condition\n",
    "    if (signal > profit_constant) and (long_signal > 0.012) and pos == 0:\n",
    "        pos = 1\n",
    "        both_price = current_1min['close'].iloc[-1]\n",
    "        trade_info = {\n",
    "            \"timestamp\": current_1min['timestamp'].iloc[-1],\n",
    "            \"trade_type\": \"BUY\",\n",
    "            \"price\": both_price,\n",
    "            \"signal\": signal,\n",
    "            \"long_signal\": long_signal,\n",
    "            \"long_highest_forecast\": long_highest_forecast\n",
    "        }\n",
    "\n",
    "    # SELL condition\n",
    "    if both_price is not None and pos == 1:\n",
    "        exit_potential = ((long_highest_forecast - both_price) / both_price) * 100\n",
    "        if (signal < (profit_constant - 0.004)) and exit_potential < 0.02:\n",
    "            pos = 0\n",
    "            trade_info = {\n",
    "                \"timestamp\": current_1min['timestamp'].iloc[-1],\n",
    "                \"trade_type\": \"SELL\",\n",
    "                \"price\": current_1min['close'].iloc[-1],\n",
    "                \"signal\": signal,\n",
    "                \"long_signal\": long_signal,\n",
    "                \"long_highest_forecast\": long_highest_forecast\n",
    "            }\n",
    "            both_price = None\n",
    "\n",
    "    # Save only trades\n",
    "    if trade_info:\n",
    "        trade_log.append(trade_info)\n",
    "\n",
