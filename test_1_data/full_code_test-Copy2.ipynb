    "\n",
    "    # Create targets for this lookahead\n",
    "    future_prices = np.vstack([\n",
    "        df_vis['current_price'].shift(-i).values for i in range(1, lookahead + 1)\n",
    "    ]).T\n",
    "\n",
    "    df_vis['max_future_price'] = np.nanmax(future_prices, axis=1)\n",
    "    df_vis['profit_pct'] = (df_vis['max_future_price'] - df_vis['current_price']) / df_vis['current_price']\n",
    "    df_vis['target'] = (df_vis['profit_pct'] >= 0.02).astype(int)\n",
    "    df_vis = df_vis.dropna(subset=['target', 'current_price'])\n",
    "\n",
    "    prices = df_vis['current_price'].reset_index(drop=True)\n",
    "    targets = df_vis['target'].reset_index(drop=True)\n",
    "\n",
    "    # --- Plot ---\n",
    "    fig, ax = plt.subplots(figsize=(, 6))  # use (100, 6) for very long plots if needed\n",
