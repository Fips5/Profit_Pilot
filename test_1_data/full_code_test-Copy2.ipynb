    "        color = 'green' if targets[i] == 1 else 'red'\n",
    "        ax.plot([i-1, i], [prices[i-1], prices[i]], color=color, linewidth=2)\n",
    "        ax.scatter(i, prices[i], color=color, s=20)\n",
    "\n",
