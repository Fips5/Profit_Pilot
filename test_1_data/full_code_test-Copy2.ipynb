    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "# Load data\n",
    "df = pd.read_csv(\"example_afther_forecast_cycle_df_15min.csv\")\n",
    "\n",
    "# --- STEP 1: BASIC SETUP ---\n",
    "\n",
    "# Rename columns if needed to ensure consistency\n",
    "forecast_cols = [\"forecast+AF8-0\", \"forecast+AF8-1\", \"forecast+AF8-2\", \"forecast+AF8-3\", \"forecast+AF8-4\"]\n",
    "assert all(col in df.columns for col in forecast_cols), \"Missing forecast columns\"\n",
    "\n",
    "# Assume current price is real price at time of forecast\n",
    "# You might need to change this to match your column name\n",
    "if 'price' in df.columns:\n",
    "    df['current_price'] = df['price']\n",
    "elif 'close' in df.columns:\n",
    "    df['current_price'] = df['close']\n",
    "else:\n",
    "    raise ValueError(\"No column found for actual price ŌĆö expected 'price' or 'close'\")\n",
    "\n",
    "\n",
    "# --- STEP 2: FEATURE ENGINEERING ---\n",
    "\n",
    "# 1. forecast_mean\n",
    "df['forecast_mean'] = df[forecast_cols].mean(axis=1)\n",
    "\n",
    "# 2. forecast_max_delta\n",
    "df['forecast_max_delta'] = df[forecast_cols].max(axis=1) - df[forecast_cols].min(axis=1)\n",
    "\n",
    "# 3. forecast_trend (slope of linear regression line across forecast steps)\n",
    "def compute_trend(row):\n",
    "    x = np.arange(5).reshape(-1, 1)\n",
    "    y = row[forecast_cols].values.reshape(-1, 1)\n",
    "    model = LinearRegression().fit(x, y)\n",
    "    return model.coef_[0][0]\n",
    "\n",
    "df['forecast_trend'] = df[forecast_cols].apply(compute_trend, axis=1)\n",
    "\n",
    "# 4. volatility_recent (standard deviation over past 5 prices)\n",
    "df['volatility_recent'] = df['current_price'].rolling(window=5).std()\n",
    "\n",
    "# 5. momentum_3 (3-step price % change)\n",
    "df['momentum_3'] = df['current_price'].pct_change(periods=3)\n",
    "\n",
    "# 6. forecast_relative\n",
    "df['forecast_relative'] = (df['forecast+AF8-4'] - df['current_price']) / df['current_price']\n",
    "\n",
    "# 7. forecast_bias\n",
    "df['price_4steps_ago'] = df['current_price'].shift(4)\n",
    "df['forecast_bias'] = (df['forecast+AF8-4'] - df['price_4steps_ago']) / df['price_4steps_ago']\n",
    "\n",
    "# 8. price_above_ma (10-step simple moving average)\n",
    "df['price_ma_10'] = df['current_price'].rolling(window=10).mean()\n",
    "df['price_above_ma'] = (df['current_price'] > df['price_ma_10']).astype(int)\n",
    "\n",
    "\n",
    "# --- STEP 3: CREATE TARGET COLUMN ---\n",
    "\n",
    "# Define how many future steps to look ahead (e.g., next 10 steps)\n",
    "LOOKAHEAD = 100\n",
    "\n",
    "# We assume data is in order by time\n",
    "future_prices = np.vstack([\n",
    "    df['current_price'].shift(-i).values for i in range(1, LOOKAHEAD + 1)\n",
    "]).T\n",
    "\n",
    "# Calculate the maximum future price from the current point\n",
    "df['max_future_price'] = np.nanmax(future_prices, axis=1)\n",
    "\n",
    "# Calculate profit percentage\n",
    "df['profit_pct'] = (df['max_future_price'] - df['current_price']) / df['current_price']\n",
    "\n",
    "# Define target\n",
    "df['target'] = (df['profit_pct'] >= 0.02).astype(int)\n",
    "\n",
    "\n",
    "# --- STEP 4: FINAL CLEANUP ---\n",
    "\n",
    "# Drop rows with NaNs due to rolling/shift operations\n",
    "df_model = df.dropna(subset=[\n",
    "    'forecast_mean', 'forecast_max_delta', 'forecast_trend',\n",
    "    'volatility_recent', 'momentum_3', 'forecast_relative',\n",
    "    'forecast_bias', 'price_above_ma', 'target'\n",
    "]).copy()\n",
    "\n",
    "# Final set of features to use\n",
    "feature_cols = [\n",
    "    'forecast_mean', 'forecast_max_delta', 'forecast_trend',\n",
    "    'volatility_recent', 'momentum_3', 'forecast_relative',\n",
    "    'forecast_bias', 'price_above_ma'\n",
    "]\n",
    "\n",
    "# Features and labels ready\n",
    "X = df_model[feature_cols]\n",
    "y = df_model['target']\n",
    "\n",
    "print(\"Ō£ģ Data is ready for training.\")\n",
    "print(\"­¤öó Feature shape:\", X.shape)\n",
    "print(\"­¤ōŖ Target distribution:\\n\", y.value_counts())\n"
   ]
  },
