   "source": [
    "def evaluate_strategy(df, target_col='target', price_col='current_price', commission=0.01):\n",
    "    \"\"\"\n",
    "    Simulates a trading strategy based on the target column and computes the profit factor.\n",
    "    \"\"\"\n",
    "    position_open = False\n",
    "    entry_price = 0\n",
    "    profits = []\n",
    "\n",
    "    for i in range(1, len(df)):\n",
    "        prev_t, curr_t = df[target_col].iloc[i - 1], df[target_col].iloc[i]\n",
    "        price = df[price_col].iloc[i]\n",
    "\n",
    "        # Open position\n",
    "        if not position_open and prev_t == 0 and curr_t == 1:\n",
    "            position_open = True\n",
    "            entry_price = price\n",
    "            entry_fee = commission * entry_price\n",
    "\n",
    "        # Close position\n",
    "        elif position_open and prev_t == 1 and curr_t == 0:\n",
    "            exit_price = price\n",
    "            exit_fee = commission * exit_price\n",
    "            raw_profit = exit_price - entry_price\n",
    "            net_profit = raw_profit - entry_fee - exit_fee\n",
    "            profits.append(net_profit)\n",
    "            position_open = False\n",
    "\n",
    "    total_profit = sum(p for p in profits if p > 0)\n",
    "    total_loss = -sum(p for p in profits if p < 0)\n",
    "\n",
    "    profit_factor = total_profit / total_loss if total_loss > 0 else float('inf')\n",
    "\n",
    "    return profit_factor, total_profit, total_loss, len(profits)\n",
    "\n",
    "# --- STEP 5: TEST ALL LOOKAHEAD VALUES ---\n",
    "\n",
    "results = []\n",
    "\n",
    "max_lookahead = len(df_model) - 1  # just to be safe, you can cap at e.g. 50\n",
    "print(\"Testing lookahead values from 1 to\", max_lookahead)\n",
    "\n",
    "for lookahead in range(1, max_lookahead + 1):\n",
    "    df_test = df_model.copy()\n",
    "\n",
    "    # Build future price matrix for this lookahead\n",
    "    future_prices = np.vstack([\n",
    "        df_test['current_price'].shift(-i).values for i in range(1, lookahead + 1)\n",
    "    ]).T\n",
    "\n",
    "    df_test['max_future_price'] = np.nanmax(future_prices, axis=1)\n",
    "    df_test['profit_pct'] = (df_test['max_future_price'] - df_test['current_price']) / df_test['current_price']\n",
    "    df_test['target'] = (df_test['profit_pct'] >= 0.02).astype(int)\n",
    "\n",
    "    df_test = df_test.dropna(subset=['target'])\n",
    "\n",
    "    pf, profit_sum, loss_sum, n_trades = evaluate_strategy(df_test)\n",
    "\n",
    "    results.append({\n",
    "        'lookahead': lookahead,\n",
    "        'profit_factor': pf,\n",
    "        'total_profit': profit_sum,\n",
    "        'total_loss': loss_sum,\n",
    "        'num_trades': n_trades\n",
    "    })\n",
    "\n",
    "# --- STEP 6: Find Best Lookahead ---\n",
    "\n",
    "results_df = pd.DataFrame(results)\n",
    "results_df = results_df.sort_values(by='profit_factor', ascending=False)\n",
    "\n",
    "print(\"\\n­¤ōł Top Lookahead Settings by Profit Factor:\\n\")\n",
    "print(results_df.head(10))z\\\n"
   ]
  },
