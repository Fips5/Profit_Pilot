    "    soup = BeautifulSoup(response.content, 'html.parser')\n",
    "    table_body = soup.find('tbody')\n",
    "    if not table_body:\n",
    "        print(f\"No data found for {symbol}.\")\n",
    "        return pd.DataFrame()\n",
    "    rows = table_body.find_all('tr')\n",
    "    data = []\n",
    "    for row in rows:\n",
    "        cols = row.find_all('td')\n",
