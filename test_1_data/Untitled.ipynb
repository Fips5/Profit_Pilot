  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b5310835-c307-4a32-a331-8572b559e1fa",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Full test version integrating your instructions\n",
    "# - Generates two predictions: one simulated, one real\n",
    "# - Applies regression correction to forecast\n",
    "# - Compares forecasted % change to real % change\n",
    "# - Returns True if price change after regression is < 1%\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from darts import TimeSeries\n",
    "from darts.dataprocessing.transformers import Scaler\n",
    "\n",
    "\n",
    "7\n",
    "\n",
    "def get_real_future_data(df, forecast_horizon):\n",
    "    \"\"\"Extracts historical data from when the forecast would have ended.\"\"\"\n",
    "    minutes_back = (forecast_horizon * 5) + 5\n",
    "    end_time = df[\"timestamp\"].max()\n",
    "    start_time = end_time - pd.Timedelta(minutes=minutes_back)\n",
    "    return df[df[\"timestamp\"] >= start_time].reset_index(drop=True)\n",
    "\n",
    "\n",
    "def train_forecast_regressor(forecast, real):\n",
    "    \"\"\"Trains a linear regressor to align forecast with reality.\"\"\"\n",
    "    reg = LinearRegression()\n",
    "    forecast = np.array(forecast).reshape(-1, 1)\n",
    "    real = np.array(real).reshape(-1, 1)\n",
    "    reg.fit(forecast, real)\n",
    "    return reg\n",
    "\n",
    "\n",
    "def apply_regression_and_compare(model, df, forecast_horizon):\n",
    "    # Create simulated input to \"trick\" TFT\n",
    "    simulated_input = create_simulated_forecast_input(df, forecast_horizon)\n",
    "\n",
    "    series = TimeSeries.from_dataframe(simulated_input, time_col=\"timestamp\", value_cols=\"close\", freq=\"5min\")\n",
    "    scaler = Scaler()\n",
    "    scaled_series = scaler.fit_transform(series)\n",
    "\n",
    "    forecast = model.predict(n=forecast_horizon, series=scaled_series)\n",
    "    forecast = scaler.inverse_transform(forecast)\n",
    "    forecast_values = forecast.values().flatten()\n",
    "\n",
    "    # Extract actual future prices from real market history\n",
    "    actual_future_df = get_real_future_data(df, forecast_horizon)\n",
    "    actual_values = actual_future_df[\"close\"].iloc[:forecast_horizon].values\n",
    "\n",
    "    # Train regression and apply correction\n",
    "    reg = train_forecast_regressor(forecast_values, actual_values)\n",
    "    corrected_forecast = reg.predict(forecast_values.reshape(-1, 1)).flatten()\n",
    "\n",
    "    # Calculate % change after correction\n",
    "    price_change = (max(corrected_forecast) - corrected_forecast[0]) / corrected_forecast[0]\n",
    "\n",
    "    print(f\"Initial Forecast: {forecast_values}\")\n",
    "    print(f\"Corrected Forecast: {corrected_forecast}\")\n",
    "    print(f\"Actual: {actual_values}\")\n",
    "    print(f\"Corrected Forecast Price Change: {price_change * 100:.2f}%\")\n",
    "\n",
    "    return abs(price_change) < 0.01\n"
   ]
  },
