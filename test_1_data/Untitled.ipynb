    "import pandas as pd\n",
    "import numpy as np\n",
    "import requests\n",
    "from darts import TimeSeries\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from datetime import datetime, timedelta\n",
    "\n",
    "def shift_and_align_input(df, forecast_horizon, freq_minutes=5):\n",
    "    shift_delta = timedelta(minutes=forecast_horizon * freq_minutes)\n",
    "    df_shifted = df.copy()\n",
    "    df_shifted['timestamp'] = df_shifted['timestamp'] - shift_delta\n",
    "    start_original = df['timestamp'].iloc[0]\n",
    "    start_shifted = df_shifted['timestamp'].iloc[0]\n",
    "    df_shifted['timestamp'] += (start_original - start_shifted)\n",
    "    return df_shifted.reset_index(drop=True)\n",
    "\n",
    "def get_live_data_range(ticker, start_time, end_time, api_key, interval='1min'):\n",
    "    now = datetime.utcnow()\n",
    "    if start_time > now:\n",
    "        raise RuntimeError(\"Start time is in the future.\")\n",
    "    if end_time > now:\n",
    "        print(f\"⚠️ Adjusting end_time from {end_time} to current UTC {now}\")\n",
    "        end_time = now\n",
    "\n",
    "    start_str = start_time.strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "    end_str = end_time.strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "    url = (\n",
    "        f\"https://api.twelvedata.com/time_series?\"\n",
    "        f\"symbol={ticker}&interval={interval}&apikey={api_key}\"\n",
    "        f\"&start_date={start_str}&end_date={end_str}&format=JSON&outputsize=5000\"\n",
    "    )\n",
    "    print(\"Requesting:\", url)\n",
    "    resp = requests.get(url).json()\n",
    "    if \"values\" not in resp:\n",
    "        raise RuntimeError(f\"Error fetching live data: {resp}\")\n",
    "    df = pd.DataFrame(resp[\"values\"])\n",
    "    df['timestamp'] = pd.to_datetime(df['datetime'])\n",
    "    df = df[['timestamp', 'open', 'high', 'low', 'close', 'volume']]\n",
    "    df = df.sort_values('timestamp').reset_index(drop=True)\n",
    "    for col in ['open', 'high', 'low', 'close', 'volume']:\n",
    "        df[col] = df[col].astype(float)\n",
    "    return df\n",
    "\n",
    "def calculate_pct_change(series):\n",
    "    return series.pct_change().fillna(0)\n",
    "def buy_signal(n_df, model, min_df, forecasting_horizon, ticker, api_key, freq_minutes=5, threshold=0.01):\n",
    "    n_df = technical_indicators(n_df)\n",
    "    n_df.reset_index(inplace=True)\n",
    "    n_df = n_df.sort_values('timestamp').reset_index(drop=True)\n",
    "\n",
    "    features_df = n_df.loc[:, :'Stochastic'].copy()\n",
    "    features_df['y'] = n_df['close']\n",
    "    features_df.dropna(inplace=True)\n",
    "\n",
    "    n_df = features_df\n",
    "    n_df = technical_indicators(n_df)\n",
    "    n_df.reset_index(inplace=True)\n",
    "    n_df.dropna(inplace=True)\n",
    "\n",
    "    n_df = n_df.loc[:, :'Stochastic'].copy()\n",
    "    n_df['y'] = n_df['close']\n",
    "    n_df.dropna(inplace=True)\n",
    "\n",
    "    if n_df['timestamp'].iloc[-1] < n_df['timestamp'].iloc[0]:\n",
    "        n_df = n_df.iloc[::-1].reset_index(drop=True)\n",
    "        \n",
    "    first_datetime_value = n_df['timestamp'].iloc[0]\n",
    "    las_datetime_value = n_df['timestamp'].iloc[-1]\n",
    "    print(f' first date: {first_datetime_value}')\n",
    "    print(f' last date: {las_datetime_value}')\n",
    "    print(f' n_df.shape: {n_df.shape}')\n",
    "    ansformed.end_time()\n",
    "    freq = pd.Timedelta(minutes=5)\n",
    "\n",
    "    if isinstance(current_end, pd.Timestamp) and current_end < required_end:\n",
    "        extra_steps = int(((required_end - current_end).total_seconds() / 300) + 1)\n",
    "        last_val = past_covariates_transformed.last_value()\n",
    "        extra_times = pd.date_range(start=current_end + freq, periods=extra_steps, freq=\"5T\")\n",
    "        extra_series = TimeSeries.from_times_and_values(extra_times, [last_val] * extra_steps)\n",
    "        past_covariates_transformed = past_covariates_transformed.concatenate(extra_series)\n",
    "\n",
    "    past_covariates_transformed = past_covariates_transformed.astype(\"float32\")\n",
    "\n",
    "\n",
    "    # Simulate past forecast\n",
    "    forecast_past = model.predict(n=forecasting_horizon, series=past_covariates_transformedt)\n",
    "    forecast_past_values = forecast_past.values().flatten()\n",
    "\n",
    "    forecast_start = past_input_df['timestamp'].iloc[-1] + timedelta(minutes=freq_minutes)\n",
    "    forecast_end = forecast_start + timedelta(minutes=forecasting_horizon * freq_minutes)\n",
    "    live_real_df = get_live_data_range(ticker, forecast_start, forecast_end, api_key, interval='1min')\n",
    "\n",
    "    live_real_df['timestamp'] = live_real_df['timestamp'].dt.tz_localize(None)\n",
    "    live_real_resampled = live_real_df.set_index('timestamp').resample(f\"{freq_minutes}T\").last().dropna().reset_index()\n",
    "\n",
    "    fc_pct = calculate_pct_change(pd.Series(forecast_past_values))\n",
    "    real_pct = calculate_pct_change(live_real_resampled['close'])\n",
    "\n",
    "    min_len = min(len(fc_pct), len(real_pct))\n",
    "    fc_pct = fc_pct.iloc[:min_len].values.reshape(-1,1)\n",
    "    real_pct = real_pct.iloc[:min_len].values\n",
    "\n",
    "    reg = LinearRegression()\n",
    "    reg.fit(fc_pct, real_pct)\n",
    "\n",
    "    forecast_live = model.predict(n=forecasting_horizon, series=series_current)\n",
    "    forecast_live_values = forecast_live.values().flatten()\n",
    "    live_fc_pct = calculate_pct_change(pd.Series(forecast_live_values)).values.reshape(-1,1)\n",
    "    corrected_pct = reg.predict(live_fc_pct)\n",
    "    max_corr_pct = corrected_pct.max()\n",
    "\n",
    "    print(f\"Max corrected predicted % price change: {max_corr_pct*100:.4f}%\")\n",
    "    signal = max_corr_pct < threshold\n",
    "    print(f\"Buy signal: {signal}\")\n",
    "    return signal\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    import warnings\n",
    "    warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "    ticker = \"CCL\"\n",
    "    api_key = \"f13c5ee6ed5c46c99e5a4022dc41d02f\"\n",
    "    dates = pd.date_range(end=pd.Timestamp.utcnow(), freq=\"5min\", periods=36)\n",
    "    prices = np.linspace(20, 20.5, 36) + np.random.normal(0, 0.02, 36)\n",
    "    n_df = pd.DataFrame({\"timestamp\": dates, \"close\": prices})\n",
    "    dates_1 = pd.date_range(end=pd.Timestamp.utcnow(), freq=\"1min\", periods=180)\n",
    "    prices_1 = np.linspace(20, 20.5, 180) + np.random.normal(0, 0.01, 180)\n",
    "    min_df = pd.DataFrame({\"timestamp\": dates_1, \"close\": prices_1})\n",
    "    forecasting_horizon = 6\n",
    "\n",
    "    signal = buy_signal(n_df, model, min_df, forecasting_horizon, ticker, api_key, freq_minutes=5, threshold=0.01)\n",
    "    print(\"Final buy signal:\", signal)\n"
   ]
